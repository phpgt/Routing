{
	"name": "phpgt/routing",
	"description": "Routes HTTP requests to your code.",
	"type": "library",

	"require": {
		"php": ">=8.1",
		"phpgt/typesafegetter": "^1.2.2",
		"phpgt/config": "^1.1.0",
		"phpgt/http": "^1",
		"phpgt/servicecontainer": "1.*",
		"psr/http-message": "^2",

		"willdurand/negotiation": "^3.0"
	},

	"require-dev": {
		"phpstan/phpstan": "^1.10",
		"phpunit/phpunit": "^10.2",
		"phpmd/phpmd": "^2.13",
		"squizlabs/php_codesniffer": "^3.7"
	},

	"license": "MIT",

	"authors": [
		{
			"name": "Greg Bowler",
			"homepage": "https://www.g105b.com",
			"email": "greg.bowler@g105b.com",
			"role": "Developer"
		}
	],

	"autoload": {
		"psr-4": {
			"GT\\Routing\\": "./src",
			"Gt\\Routing\\": "./src"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"GT\\Routing\\Test\\": "./test/phpunit",
			"Gt\\Routing\\Test\\": "./test/phpunit"
		}
	},
	"config": {
		"platform": {
			"php": "8.1.0"
		}
	},

	"scripts": {
		"phpunit": "vendor/bin/phpunit --configuration phpunit.xml",
		"phpstan": "vendor/bin/phpstan analyse --level 6 src --memory-limit 256M",
		"phpcs": "vendor/bin/phpcs src --standard=phpcs.xml",
		"phpmd": "vendor/bin/phpmd src/ text phpmd.xml",
		"test": [
			"@phpunit",
			"@phpstan",
			"@phpcs",
			"@phpmd"
		]
	},
	"keywords": [
		"router",
		"route",
		"uri",
		"url",
		"request",
		"redirect",
		"assembly",
		"view",
		"logic"
	],
	"funding": [
		{
			"type": "github",
			"url": "https://github.com/sponsors/phpgt"
		}
	]
}
